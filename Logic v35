# Core day loop
# ─────────────────────────────────────────────────────────────────────────────

def backtest_day(day_df, date):
    trades     = []
    timestamps = sorted(day_df["timestamp"].unique())

    def snap(ts):
        return day_df[day_df["timestamp"] == ts]

    ts_open   = pd.Timestamp(str(date) + " 09:15:00")
    open_snap = snap(ts_open)
    if open_snap.empty and timestamps:
        open_snap = day_df[day_df["timestamp"] == timestamps[0]]
    open_ref = float(open_snap.iloc[0]["spot"]) if not open_snap.empty else None

    in_trade       = False
    entry_px = entry_ts = direction = entry_strike = entry_offset = None
    e_atm_c = e_atm_p = e_outer_c = e_outer_p = e_spot = None
    e_atm_imb = e_outer_imb = None
    e_trade_num = 0
    trail_on       = False
    oi_exit_consec = 0

    day_pnl      = 0.0
    trades_today = 0
    reentry_after = None

    for ts in timestamps:
        t = ts.time()
        if t < SCAN_START:
            continue

        if t > HARD_EXIT:
            if in_trade:
                s   = snap(ts)
                row = s[s["strike"] == entry_strike]
                col = "close_call" if direction == "CALL" else "close_put"
                px  = float(row.iloc[0][col]) if not row.empty else entry_px
                pnl = (px - entry_px) * LOT
                day_pnl += pnl
                trades.append(make_record(
                    date, entry_ts, ts, direction, entry_strike,
                    entry_px, px, pnl, "HARD_EXIT", e_trade_num,
                    e_atm_c, e_atm_p, e_outer_c, e_outer_p,
                    e_atm_imb, e_outer_imb,
                    open_ref, e_spot, entry_offset, exit_snap=s))
                in_trade = False
            break

        s        = snap(ts)
        cur_spot = float(s.iloc[0]["spot"]) if not s.empty else np.nan

        # ══════════════════════════════════════════════════════════════════
        # IN TRADE
        # ══════════════════════════════════════════════════════════════════
        if in_trade:
            row = s[s["strike"] == entry_strike]
            if row.empty:
                continue
            col        = "close_call" if direction == "CALL" else "close_put"
            current_px = float(row.iloc[0][col])
            if np.isnan(current_px):
                continue

            # Premium exits
            should_exit, reason, trail_on = check_premium_exit(
                entry_px, current_px, trail_on)
            if should_exit:
                pnl = (current_px - entry_px) * LOT
                day_pnl += pnl
                trades.append(make_record(
                    date, entry_ts, ts, direction, entry_strike,
                    entry_px, current_px, pnl, reason, e_trade_num,
                    e_atm_c, e_atm_p, e_outer_c, e_outer_p,
                    e_atm_imb, e_outer_imb,
                    open_ref, e_spot, entry_offset, exit_snap=s))
                in_trade       = False
                trail_on       = False
                oi_exit_consec = 0
                trades_today  += 1
                reentry_after  = ts + pd.Timedelta(minutes=REENTRY_COOLDOWN)
                continue

            # OI exit — ratio-based, symmetric
            atm_c2, atm_p2     = atm_oi(s)
            outer_c2, outer_p2 = outer_oi(s)
            atm_imb2    = imbalance_ratio(atm_c2, atm_p2)
            outer_imb2  = imbalance_ratio(outer_c2, outer_p2)
            atm_dir2    = "CALL" if atm_c2   < atm_p2   else "PUT"
            outer_dir2  = "CALL" if outer_c2 < outer_p2 else "PUT"

            atm_ok   = (atm_imb2   >= EXIT_IMBALANCE_MIN) and (atm_dir2   == direction)
            outer_ok = (outer_imb2 >= EXIT_IMBALANCE_MIN) and (outer_dir2 == direction)

            if atm_ok and not outer_ok:
                oi_exit_consec = 0   # outer alone fell — ignore, stay in
            elif not atm_ok:
                oi_exit_consec += 1
            elif atm_dir2 != direction or outer_dir2 != direction:
                oi_exit_consec += 1
            else:
                oi_exit_consec = 0

            if oi_exit_consec >= EXIT_PERSIST:
                pnl = (current_px - entry_px) * LOT
                day_pnl += pnl
                if atm_imb2 < EXIT_IMBALANCE_MIN and outer_imb2 < EXIT_IMBALANCE_MIN:
                    exit_reason = "OI_EXIT_BOTH_FELL"
                elif atm_imb2 < EXIT_IMBALANCE_MIN:
                    exit_reason = "OI_EXIT_ATM_FELL"
                else:
                    exit_reason = "OI_EXIT_DIR_FLIP"
                trades.append(make_record(
                    date, entry_ts, ts, direction, entry_strike,
                    entry_px, current_px, pnl, exit_reason, e_trade_num,
                    e_atm_c, e_atm_p, e_outer_c, e_outer_p,
                    e_atm_imb, e_outer_imb,
                    open_ref, e_spot, entry_offset, exit_snap=s))
                in_trade       = False
                trail_on       = False
                oi_exit_consec = 0
                trades_today  += 1
                reentry_after  = ts + pd.Timedelta(minutes=REENTRY_COOLDOWN)

        # ══════════════════════════════════════════════════════════════════
        # NOT IN TRADE
        # ══════════════════════════════════════════════════════════════════
        else:
            if t > ENTRY_CUTOFF:
                continue
            if trades_today >= MAX_TRADES_DAY:
                continue
            if day_pnl <= DAILY_LOSS_LIMIT:
                continue
            if reentry_after and ts < reentry_after:
                continue
            if BLOCK_HOUR_START <= t <= BLOCK_HOUR_END:
                continue

            # Evaluate entry signal (imbalance ratio based)
            atm_dir, outer_dir, atm_imb, outer_imb, atm_c, atm_p, outer_c, outer_p = \
                check_oi_direction(s)

            if atm_imb < ATM_IMBALANCE_MIN:
                continue
            if outer_imb < OUTER_IMBALANCE_MIN:
                continue
            if atm_dir != outer_dir:
                continue

            ratio = atm_ratio_val(atm_c, atm_p)
            if ratio < MIN_ATM_RATIO:
                continue

            # Outer/ATM noise filter
            atm_diff_now   = abs(atm_c - atm_p)
            outer_diff_now = abs(outer_c - outer_p)
            if atm_diff_now > 0 and (outer_diff_now / atm_diff_now) > MAX_OUTER_ATM_RATIO:
                continue

            sig_dir = atm_dir

            # FINDING 1: Skip CALL when spot is in the partial dip zone (-30 to 0)
            # Analysis showed: 0% win rate on 4 CALL trades in this zone (all losers)
            # Why: spot just below open = market still in mild decline, CALL signal unreliable
            # NOT blocked: CALL when spot < -30 (big drop = OI shift is genuine = 100% win)
            if open_ref is not None and not np.isnan(cur_spot):
                svopen = cur_spot - open_ref
                if sig_dir == "CALL" and CALL_BLOCK_ZONE_LOW <= svopen <= CALL_BLOCK_ZONE_HIGH:
                    continue   # CALL in dip zone → skip (0% win historically)

            # OI trend confirmation: signal must have been present N consecutive minutes
            if not oi_trend_ok(day_df, ts, sig_dir, OI_TREND_MINS):
                continue   # signal appeared but hasn't been trending yet

            # Premium check (FINDING 2: MIN_PREMIUM raised to 30 — ₹20-30 only 44% win)
            off = 2 if sig_dir == "CALL" else -2
            row = s[s["strike_offset"] == off]
            if row.empty:
                continue
            col = "close_call" if sig_dir == "CALL" else "close_put"
            px  = float(row.iloc[0][col])
            if np.isnan(px) or px < MIN_PREMIUM or px > MAX_ENTRY_PREMIUM:
                continue

            entry_px       = px
            entry_ts       = ts
            direction      = sig_dir
            entry_strike   = float(row.iloc[0]["strike"])
            entry_offset   = off
            e_atm_c, e_atm_p     = atm_c, atm_p
            e_outer_c, e_outer_p = outer_c, outer_p
            e_atm_imb, e_outer_imb = atm_imb, outer_imb
            e_spot         = cur_spot
            e_trade_num    = trades_today + 1
            in_trade       = True
            trail_on       = False
            oi_exit_consec = 0

    return trades


# ─────────────────────────────────────────────────────────────────────────────
# Runner + Report
# ─────────────────────────────────────────────────────────────────────────────

def run_backtest(df):
    all_trades = []
    dates = sorted(df["date"].unique())
    print(f"Running v35 on {len(dates)} days")
    print(f"  Entry: ATM imbalance>={ATM_IMBALANCE_MIN*100:.0f}% + Outer>={OUTER_IMBALANCE_MIN*100:.0f}%  (v29 base)")
    print(f"  NEW FILTER 1: Skip CALL when spot_vs_open between {CALL_BLOCK_ZONE_LOW} and {CALL_BLOCK_ZONE_HIGH}")
    print(f"  NEW FILTER 2: Min premium raised Rs20 -> Rs{int(MIN_PREMIUM)}")
    print(f"  Trend confirm: {OI_TREND_MINS} min | SL {int(SL_PCT*100)}% | Target {int(TARGET_PCT*100)}%")
    print(f"  Max {MAX_TRADES_DAY} trades/day | hr10 blocked | prem <=180 | SL {int(SL_PCT*100)}%")
    print()

    for d in dates:
        day_df = df[df["date"] == d].copy()
        trades = backtest_day(day_df, d)
        day_pnl = sum(tr["pnl_per_lot"] for tr in trades)
        dow = pd.Timestamp(str(d)).day_name()[:3]
        flag = "  <<< NEGATIVE" if day_pnl < 0 else ""
        print(f"  {d} ({dow})  trades={len(trades):2d}  P&L=INR {day_pnl:>10,.0f}{flag}")
        all_trades.extend(trades)

    return pd.DataFrame(all_trades)


def print_summary(df, dates_count):
    if df.empty:
        print("No trades generated.")
        return None

    wins   = df[df["pnl_per_lot"] > 0]
    losses = df[df["pnl_per_lot"] <= 0]
    n   = len(df)
    gp  = wins["pnl_per_lot"].sum()
    gl  = abs(losses["pnl_per_lot"].sum())
    net = df["pnl_per_lot"].sum()
    wr  = len(wins) / n * 100
    pf  = gp / gl if gl > 0 else float("inf")
    aw  = wins["pnl_per_lot"].mean() if len(wins) else 0
    al  = losses["pnl_per_lot"].mean() if len(losses) else 0
    exp = (wr / 100) * aw + (1 - wr / 100) * al
    cum = df["pnl_per_lot"].cumsum()
    mdd = (cum - cum.cummax()).min()
    streak = max_streak = 0
    for v in df["pnl_per_lot"]:
        streak = streak + 1 if v <= 0 else 0
        max_streak = max(max_streak, streak)

    day_pnl  = df.groupby("date")["pnl_per_lot"].sum()
    pos_days = (day_pnl > 0).sum()
    neg_days = (day_pnl <= 0).sum()

    rows = [
        ("Total Trades",         n),
        ("Trading Days",         dates_count),
        ("Days with Trades",     len(day_pnl)),
        ("Positive Days",        int(pos_days)),
        ("Negative Days",        int(neg_days)),
        ("Win Rate %",           round(wr, 1)),
        ("Net P&L INR",          round(net, 0)),
        ("Gross Profit INR",     round(gp, 0)),
        ("Gross Loss INR",       round(gl, 0)),
        ("Profit Factor",        round(pf, 2)),
        ("Avg Win INR",          round(aw, 0)),
        ("Avg Loss INR",         round(al, 0)),
        ("Expectancy INR",       round(exp, 0)),
        ("Max Drawdown INR",     round(mdd, 0)),
        ("Max Consec Losses",    max_streak),
        ("Avg Duration (min)",   round(df["duration_min"].mean(), 1)),
        ("Avg Trades/Day",       round(n / dates_count, 2)),
    ]
    for r, cnt in df["exit_reason"].value_counts().items():
        rows.append((f"Exit: {r}", int(cnt)))

    smry = pd.DataFrame(rows, columns=["Metric", "Value"])
    print()
    print("=" * 68)
    print("BACKTEST SUMMARY - v35  (v29 + skip CALL -30to0 zone + min premium 30)")
    print("=" * 68)
    print(smry.to_string(index=False))

    print("\n--- By Trade # ---")
    for tn, g in df.groupby("trade_num"):
        w2 = (g["pnl_per_lot"] > 0).sum() / len(g) * 100
        sl = (g["exit_reason"] == "SL_HIT").sum()
        print(f"  Trade #{tn}  trades={len(g):3d}  win={w2:.1f}%  "
              f"avg={g['pnl_per_lot'].mean():>8.0f}  total={g['pnl_per_lot'].sum():>10.0f}  SL={sl}")

    print("\n--- By Direction ---")
    for d2, g in df.groupby("direction"):
        w2 = (g["pnl_per_lot"] > 0).sum() / len(g) * 100
        print(f"  {d2:4}  trades={len(g):3d}  win={w2:.1f}%  "
              f"avg={g['pnl_per_lot'].mean():>8.0f}  total={g['pnl_per_lot'].sum():>10.0f}")

    print("\n--- By Exit Reason ---")
    for er, g in df.groupby("exit_reason"):
        print(f"  {er:<28}  trades={len(g):3d}  "
              f"avg={g['pnl_per_lot'].mean():>8.0f}  total={g['pnl_per_lot'].sum():>10.0f}")

    print("\n--- ATM Imbalance % at entry ---")
    print(f"  Winners avg: {wins['entry_atm_imb_pct'].mean():.1f}%  "
          f"Losers avg: {losses['entry_atm_imb_pct'].mean():.1f}%")

    print("\n--- By Day of Week ---")
    df["dow"] = pd.to_datetime(df["date"]).dt.day_name()
    for day in ["Monday","Tuesday","Wednesday","Thursday","Friday"]:
        g = df[df["dow"] == day]
        if g.empty: continue
        w2 = (g["pnl_per_lot"] > 0).sum() / len(g) * 100
        sl = (g["exit_reason"] == "SL_HIT").sum()
        print(f"  {day:<12}  trades={len(g):3d}  win={w2:.1f}%  "
              f"avg={g['pnl_per_lot'].mean():>8.0f}  total={g['pnl_per_lot'].sum():>10.0f}  SL={sl}")

    print("\n--- Entry hour ---")
    df["entry_hour"] = df["entry_time"].apply(lambda x: x[:2])
    for hr, g in df.groupby("entry_hour"):
        w2 = (g["pnl_per_lot"] > 0).sum() / len(g) * 100
        sl = (g["exit_reason"] == "SL_HIT").sum()
        print(f"  {hr}:xx  trades={len(g):3d}  win={w2:.1f}%  "
              f"avg={g['pnl_per_lot'].mean():>8.0f}  SL={sl}")

    print("\n--- Day-wise P&L ---")
    dpnl = day_pnl.reset_index()
    dpnl.columns = ["Date", "Net_PNL"]
    dpnl["Day"] = pd.to_datetime(dpnl["Date"]).dt.day_name().str[:3]
    dpnl["Cumulative"] = dpnl["Net_PNL"].cumsum()
    dpnl["Flag"] = dpnl["Net_PNL"].apply(lambda x: "NEGATIVE" if x < 0 else "")
    print(dpnl.to_string(index=False))
    print(f"\nPositive days: {pos_days} / {len(day_pnl)}  |  "
          f"Negative days: {neg_days} / {len(day_pnl)}")

    return smry


def main():
    print("Loading atm_joined_2026.parquet ...")
    df = load_data()
    dates_count = df["date"].nunique()
    print(f"  {len(df):,} rows | {dates_count} days | "
          f"{df['timestamp'].min().date()} to {df['timestamp'].max().date()}")
    print()

    trades_df = run_backtest(df)

    if trades_df.empty:
        print("No trades generated.")
        return

    out_trades  = OUT_DIR / "v35_trades.csv"
    out_summary = OUT_DIR / "v35_summary.csv"
    trades_df.to_csv(out_trades, index=False)

    smry = print_summary(trades_df, dates_count)
    if smry is not None:
        smry.to_csv(out_summary, index=False)

    print(f"\nSaved: {out_trades}")
    print(f"Saved: {out_summary}")


if __name__ == "__main__":
    main()
