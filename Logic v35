"""
OI Divergence Strategy  v29  — True Dynamic Threshold (Imbalance Ratio)
========================================================================

CORE PHILOSOPHY CHANGE:
  Old approach: "OI diff > 20L" — FIXED, doesn't scale with market activity
  New approach: "OI Imbalance Ratio > threshold%" — SELF-CALIBRATING

  ATM Imbalance Ratio  = |call_oi - put_oi| / (call_oi + put_oi)
  Outer Imbalance Ratio = |outer_call - outer_put| / (outer_call + outer_put)

  This ratio is 0 when perfectly balanced, 1.0 when completely one-sided.
  It AUTOMATICALLY scales with market activity:
    Busy day  (ATM total = 400L): 15% ratio requires 60L diff  (harder to signal)
    Average day (ATM total = 180L): 15% ratio requires 27L diff (normal)
    Quiet day  (ATM total = 80L):  15% ratio requires 12L diff  (easier to signal)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
INNOVATION 1 — SELF-CALIBRATING ENTRY (Imbalance Ratio)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Entry condition:
  ATM Imbalance Ratio   >= ATM_IMBALANCE_MIN   (e.g. 0.15 = 15%)
  Outer Imbalance Ratio >= OUTER_IMBALANCE_MIN  (e.g. 0.06 = 6%)
  Both must agree on the same direction
  ATM ratio (put/call extremity) >= 1.5

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
INNOVATION 2 — OI TREND CONFIRMATION (signal must be building)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Before entering, check that the OI signal has been consistently in
the SAME direction for at least OI_TREND_MINS consecutive minutes.
This eliminates one-minute-wonder signals that appear and flip.

  OI direction has been CALL for 3+ consecutive minutes → trend confirmed
  If direction appeared just this minute → skip, wait

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
INNOVATION 3 — SYMMETRIC EXIT with imbalance ratio
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
Exit when ATM imbalance ratio drops below EXIT_IMBALANCE_MIN (0.07)
OR direction flips — same symmetric logic as v23 but ratio-based.
No asymmetric hold (that caused 22 negative days in v28).

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ALL OTHER RULES:
  ATM+/-2 entry | Max 4 trades/day | Hour-10 blocked
  Premium ₹20-₹180 | outer/ATM ratio <= 5.0
  SL 20% | Target 100% | Trail +70%/+20%
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Run: py -3 backtest_v29.py
"""

import pandas as pd
import numpy as np
from pathlib import Path

DATA_FILE  = Path(__file__).parent / "atm_joined_2026.parquet"
OUT_DIR    = Path(__file__).parent / "results"
OUT_DIR.mkdir(exist_ok=True)

LAKH = 100_000
LOT  = 75

# ── Dynamic imbalance thresholds (replace fixed 20L) ─────────────────────────
# Entry: OI must be at least this % imbalanced
ATM_IMBALANCE_MIN   = 0.15   # 15% of total ATM OI must be on one side
OUTER_IMBALANCE_MIN = 0.06   # 6%  of total outer OI

# Exit: ATM imbalance dropped below this % → signal gone
EXIT_IMBALANCE_MIN  = 0.07   # 7% (lower than entry = some tolerance before exiting)

# ── OI trend confirmation ─────────────────────────────────────────────────────
OI_TREND_MINS = 3   # ATM direction must have been consistent for N minutes

# ── All other params same as v23 ─────────────────────────────────────────────
MIN_ATM_RATIO        = 1.5
MAX_OUTER_ATM_RATIO  = 5.0
MAX_ENTRY_PREMIUM    = 180.0
EXIT_PERSIST         = 2
MAX_TRADES_DAY       = 4

SL_PCT         = 0.20
TARGET_PCT     = 1.00
TRAIL_TRIG_PCT = 0.70
TRAIL_LOCK_PCT = 0.20

SCAN_START       = pd.Timestamp("09:20").time()
ENTRY_CUTOFF     = pd.Timestamp("15:15").time()
HARD_EXIT        = pd.Timestamp("15:19").time()
MIN_PREMIUM      = 30.0   # RAISED from 20 → 30 (₹20-30 options only 44.4% win rate, 5 SL hits)
REENTRY_COOLDOWN = 5
DAILY_LOSS_LIMIT = -8000
BLOCK_HOUR_START = pd.Timestamp("10:00").time()
BLOCK_HOUR_END   = pd.Timestamp("10:59").time()

# ── Finding 1: Skip CALL when spot is in the "dip zone" ──────────────────────
# Analysis: CALL when spot_vs_open is between -30 and 0 = 0% win rate (4 trades, all losers)
# Market has dipped slightly from open but hasn't recovered → still in decline mode
# Paradox: CALL when spot < -30 (big drop) = 100% win (8 trades)  ← keep those
# So only block the partial/uncertain dip zone (-30 to 0)
CALL_BLOCK_ZONE_LOW  = -30.0   # CALL blocked when spot_vs_open >= this
CALL_BLOCK_ZONE_HIGH =   0.0   # CALL blocked when spot_vs_open <= this


# ─────────────────────────────────────────────────────────────────────────────
# OI helpers
# ─────────────────────────────────────────────────────────────────────────────

def load_data():
    df = pd.read_parquet(DATA_FILE)
    df["timestamp"] = pd.to_datetime(df["timestamp"])
    df["date"] = df["timestamp"].dt.date
    df.sort_values(["timestamp", "strike_offset"], inplace=True)
    return df


def atm_oi(snap):
    row = snap[snap["strike_offset"] == 0]
    if row.empty:
        return 0, 0
    return int(row.iloc[0]["oi_call"]), int(row.iloc[0]["oi_put"])


def outer_oi(snap):
    c = snap[snap["strike_offset"].isin([1, 2])]["oi_call"].sum()
    p = snap[snap["strike_offset"].isin([-1, -2])]["oi_put"].sum()
    return int(c), int(p)


def imbalance_ratio(a, b):
    """
    |a - b| / (a + b) — returns 0 to 1.
    0 = perfectly balanced, 1 = completely one-sided.
    """
    total = a + b
    if total == 0:
        return 0.0
    return abs(a - b) / total


def atm_ratio_val(atm_c, atm_p):
    if atm_c == 0 or atm_p == 0:
        return 0.0
    return max(atm_p / atm_c, atm_c / atm_p)


def check_oi_direction(snap):
    """
    Returns (atm_dir, outer_dir, atm_imb, outer_imb) or None if no valid snap.
    """
    atm_c, atm_p     = atm_oi(snap)
    outer_c, outer_p = outer_oi(snap)
    atm_imb   = imbalance_ratio(atm_c, atm_p)
    outer_imb = imbalance_ratio(outer_c, outer_p)
    atm_dir   = "CALL" if atm_c < atm_p else "PUT"
    outer_dir = "CALL" if outer_c < outer_p else "PUT"
    return atm_dir, outer_dir, atm_imb, outer_imb, atm_c, atm_p, outer_c, outer_p


def oi_trend_ok(day_df, current_ts, signal_dir, lookback):
    """
    Check that ATM OI direction has been CONSISTENTLY signal_dir for
    the last `lookback` consecutive minutes (including current minute).
    Returns True if trending confirmed.
    """
    atm_rows = day_df[day_df["strike_offset"] == 0].sort_values("timestamp")
    past = atm_rows[atm_rows["timestamp"] <= current_ts].tail(lookback)
    if len(past) < lookback:
        return False   # not enough history yet (e.g. first few minutes)
    for _, row in past.iterrows():
        c = int(row["oi_call"]); p = int(row["oi_put"])
        minute_dir = "CALL" if c < p else "PUT"
        if minute_dir != signal_dir:
            return False   # direction was different at some point
    return True


def check_premium_exit(entry_px, current_px, trail_on):
    if current_px <= entry_px * (1 - SL_PCT):
        return True, "SL_HIT", trail_on
    if current_px >= entry_px * (1 + TARGET_PCT):
        return True, "TARGET_HIT", trail_on
    if current_px >= entry_px * (1 + TRAIL_TRIG_PCT):
        trail_on = True
    if trail_on and current_px <= entry_px * (1 + TRAIL_LOCK_PCT):
        return True, "TRAIL_SL", trail_on
    return False, None, trail_on


OFFSET_LABEL = {2: "ATM+2", 1: "ATM+1", 0: "ATM", -1: "ATM-1", -2: "ATM-2"}


def make_record(date, entry_ts, exit_ts, direction, entry_strike,
                entry_px, exit_px, pnl, reason, trade_num,
                atm_c, atm_p, outer_c, outer_p,
                atm_imb, outer_imb,
                open_ref, entry_spot, entry_offset,
                exit_snap=None):
    def _L(v): return round(v / LAKH, 1) if v is not None else None
    def _pct(v): return round(v * 100, 1) if v is not None else None

    ex_atm_c = ex_atm_p = ex_outer_c = ex_outer_p = ex_atm_strike = None
    ex_atm_imb = ex_outer_imb = None
    if exit_snap is not None and not exit_snap.empty:
        arow = exit_snap[exit_snap["strike_offset"] == 0]
        if not arow.empty:
            ex_atm_strike = float(arow.iloc[0]["strike"])
            ex_atm_c = int(arow.iloc[0]["oi_call"])
            ex_atm_p = int(arow.iloc[0]["oi_put"])
            ex_atm_imb = imbalance_ratio(ex_atm_c, ex_atm_p)
        oc = exit_snap[exit_snap["strike_offset"].isin([1, 2])]["oi_call"].sum()
        op = exit_snap[exit_snap["strike_offset"].isin([-1, -2])]["oi_put"].sum()
        ex_outer_c = int(oc); ex_outer_p = int(op)
        ex_outer_imb = imbalance_ratio(ex_outer_c, ex_outer_p)

    return {
        "date":                  date,
        "day":                   pd.Timestamp(str(date)).day_name()[:3],
        "trade_num":             trade_num,
        "entry_time":            entry_ts.strftime("%H:%M"),
        "exit_time":             exit_ts.strftime("%H:%M") if exit_ts else None,
        "direction":             direction,
        "entry_strike":          entry_strike,
        "entry_offset":          OFFSET_LABEL.get(entry_offset, str(entry_offset)),
        # Entry OI
        "entry_atm_call_L":      _L(atm_c),
        "entry_atm_put_L":       _L(atm_p),
        "entry_atm_diff_L":      _L(abs(atm_c - atm_p)),
        "entry_atm_imb_pct":     _pct(atm_imb),    # NEW: imbalance %
        "entry_outer_call_L":    _L(outer_c),
        "entry_outer_put_L":     _L(outer_p),
        "entry_outer_diff_L":    _L(abs(outer_c - outer_p)),
        "entry_outer_imb_pct":   _pct(outer_imb),  # NEW: outer imbalance %
        "atm_ratio":             round(atm_ratio_val(atm_c, atm_p), 2),
        "open_ref":              round(open_ref, 1) if open_ref else None,
        "entry_spot":            round(entry_spot, 1),
        "spot_vs_open":          round(entry_spot - open_ref, 1) if open_ref else None,
        "entry_premium":         round(entry_px, 2),
        "exit_premium":          round(exit_px, 2),
        "pnl_per_lot":           round(pnl, 2),
        "exit_reason":           reason,
        "duration_min":          int((exit_ts - entry_ts).seconds / 60) if exit_ts else None,
        # Exit OI snapshot
        "exit_atm_strike":       ex_atm_strike,
        "exit_atm_call_L":       _L(ex_atm_c),
        "exit_atm_put_L":        _L(ex_atm_p),
        "exit_atm_diff_L":       _L(abs(ex_atm_c - ex_atm_p)) if ex_atm_c is not None else None,
        "exit_atm_imb_pct":      _pct(ex_atm_imb),
        "exit_outer_call_L":     _L(ex_outer_c),
        "exit_outer_put_L":      _L(ex_outer_p),
        "exit_outer_diff_L":     _L(abs(ex_outer_c - ex_outer_p)) if ex_outer_c is not None else None,
        "exit_outer_imb_pct":    _pct(ex_outer_imb),
    }


