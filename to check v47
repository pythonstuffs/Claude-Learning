"""
OI Divergence Strategy Engine — Live Forward Testing  (v47 logic)
=================================================================
Entry: v29/v37/v43 imbalance-ratio + OI trend confirmation (unchanged).
Exit:  Hybrid two-phase system —
  Phase 1 (first EARLY_ATM_BARS ticks): fast-fail ATM-alone check.
    If ATM signal fails EXIT_PERSIST consecutive bars → OI_EXIT_EARLY_ATM.
  Phase 2 (after EARLY_ATM_BARS ticks): dynamic zone exit (v43).
    Zone determined by current ATM vs entry_strike position:
      FAR_OTM  → both ATM + outer must fail × EXIT_PERSIST
      NEAR_OTM → both ATM + ring (±1) must fail × EXIT_PERSIST
      ATM      → ATM alone fails × EXIT_PERSIST
      ITM      → immediate exit on ATM direction reversal

Data source : _latest option chain (from app.py poll loop)
Execution   : paper (log only) or live (via mstock broker registry)
Per-user    : one paper engine + one live engine per registered user
"""
from __future__ import annotations

import datetime as dt
import threading
from collections import deque
from typing import Optional

import config as cfg

# ─────────────────────────────────────────────────────────────
# Constants  (v29 rules)
# ─────────────────────────────────────────────────────────────
LAKH        = 100_000
LOT         = 65
STRIKE_STEP = 50          # NIFTY 50-point intervals

# Dynamic imbalance thresholds (replace v23 fixed 20L diff)
ATM_IMBALANCE_MIN   = 0.15   # 15% of total ATM OI must be on one side
OUTER_IMBALANCE_MIN = 0.06   # 6%  of total outer OI
EXIT_IMBALANCE_MIN  = 0.07   # 7%  — ATM must still be ≥ this to stay in

# OI trend confirmation — direction must be consistent for N ticks
OI_TREND_MINS = 3

MIN_ATM_RATIO       = 1.5
MAX_OUTER_ATM_RATIO = 5.0
MIN_PREMIUM         = 30.0   # raised from 20 (₹20-30 options show 44% win rate)
MAX_ENTRY_PREMIUM   = 180.0

SL_PCT         = 0.18
TARGET_PCT     = 1.00
TRAIL_TRIG_PCT = 0.70
TRAIL_LOCK_PCT = 0.20

EXIT_PERSIST    = 2    # consecutive ticks before OI exit fires
EARLY_ATM_BARS  = 5    # first N bars: fast-fail ATM-alone gate (Phase 1)
BROKERAGE       = 300.0  # ₹ deducted from running balance per completed trade (paper + live)

# Skip CALL when spot is in the partial dip zone (-30 to 0 vs open)
CALL_BLOCK_ZONE_LOW  = -30.0
CALL_BLOCK_ZONE_HIGH =   0.0

SCAN_START_H,  SCAN_START_M  =  9, 20
ENTRY_CUTOFF_H, ENTRY_CUTOFF_M = 15, 15
HARD_EXIT_H,  HARD_EXIT_M    = 15, 19
BLOCK_START_H, BLOCK_START_M  = 10,  0
BLOCK_END_H,   BLOCK_END_M    = 10, 59

MAX_TRADES_DAY   = 4       # raised from 3 in v29
DAILY_LOSS_LIMIT = -8_000.0
REENTRY_COOLDOWN = 5       # minutes


# ─────────────────────────────────────────────────────────────
# Helpers — option chain parsing
# ─────────────────────────────────────────────────────────────

def _atm_strike(spot: float) -> int:
    return int(round(spot / STRIKE_STEP) * STRIKE_STEP)


def _get_row(rows: list, strike: int) -> Optional[dict]:
    for r in rows:
        if int(r.get("strike", -1)) == strike:
            return r
    return None


def _oi(row: Optional[dict], side: str) -> int:
    if row is None:
        return 0
    sub = row.get(side) or {}
    return int(sub.get("oi") or sub.get("oi_call") or sub.get("oi_put") or 0)


def _ltp(row: Optional[dict], side: str) -> float:
    if row is None:
        return 0.0
    sub = row.get(side) or {}
    return float(sub.get("ltp") or sub.get("close") or 0.0)


def _sec_id(row: Optional[dict], side: str) -> str:
    if row is None:
        return ""
    sub = row.get(side) or {}
    return str(sub.get("security_id") or "")


def _atm_oi(rows: list, atm: int):
    row = _get_row(rows, atm)
    return _oi(row, "call"), _oi(row, "put")


def _outer_oi(rows: list, atm: int):
    c = (_oi(_get_row(rows, atm + STRIKE_STEP), "call")
         + _oi(_get_row(rows, atm + 2 * STRIKE_STEP), "call"))
    p = (_oi(_get_row(rows, atm - STRIKE_STEP), "put")
         + _oi(_get_row(rows, atm - 2 * STRIKE_STEP), "put"))
    return c, p


def _imbalance_ratio(a: int, b: int) -> float:
    """
    |a - b| / (a + b).  0 = balanced, 1 = completely one-sided.
    Self-calibrates with total market activity — scales correctly on
    quiet/busy days without needing a fixed absolute threshold.
    """
    total = a + b
    if total == 0:
        return 0.0
    return abs(a - b) / total


def _atm_ratio(atm_c: int, atm_p: int) -> float:
    if atm_c == 0 or atm_p == 0:
        return 0.0
    return max(atm_p / atm_c, atm_c / atm_p)


_MONTH_CODE = {
    "JAN":"1","FEB":"2","MAR":"3","APR":"4","MAY":"5","JUN":"6",
    "JUL":"7","AUG":"8","SEP":"9","OCT":"O","NOV":"N","DEC":"D",
}

def _is_monthly_expiry(d: dt.date) -> bool:
    """Last Tuesday of the month = monthly expiry."""
    return (d + dt.timedelta(days=7)).month != d.month

def _mstock_trading_symbol(strike: int, opt_type: str, expiry_iso: str) -> str:
    """
    Build mStock NFO trading symbol.
      Monthly (last Tue of month): NIFTY{YY}{MMM}{STRIKE}{OPT}  e.g. NIFTY26JUN23150CE
      Weekly  (other Tuesdays):    NIFTY{YY}{M}{DD}{STRIKE}{OPT} e.g. NIFTY2661623150CE
    """
    try:
        exp  = dt.datetime.strptime(expiry_iso, "%Y-%m-%d").date()
        yy   = exp.strftime("%y")
        mon3 = exp.strftime("%b").upper()
        if _is_monthly_expiry(exp):
            return f"NIFTY{yy}{mon3}{strike}{opt_type}"
        else:
            m_char = _MONTH_CODE.get(mon3, "")
            dd = exp.strftime("%d")
            return f"NIFTY{yy}{m_char}{dd}{strike}{opt_type}"
    except Exception:
        return ""

def _nse_trading_symbol(strike: int, opt_type: str, expiry: str) -> str:
    """Legacy NSE format — kept for non-mStock brokers."""
    try:
        exp = dt.datetime.strptime(expiry, "%Y-%m-%d")
        return f"NIFTY{exp.strftime('%d%b%y').upper()}{strike}{opt_type}"
    except Exception:
        return ""


def _evaluate_entry(rows: list, atm: int):
    """
    v29 imbalance-ratio entry check.
    Returns (valid, direction, atm_c, atm_p, outer_c, outer_p,
             atm_imb, outer_imb, skip_reason)
    """
    atm_c,   atm_p   = _atm_oi(rows, atm)
    outer_c, outer_p = _outer_oi(rows, atm)

    atm_imb   = _imbalance_ratio(atm_c, atm_p)
    outer_imb = _imbalance_ratio(outer_c, outer_p)

    if atm_imb < ATM_IMBALANCE_MIN:
        return (False, None, atm_c, atm_p, outer_c, outer_p,
                atm_imb, outer_imb,
                f"ATM_IMB_LOW({atm_imb*100:.1f}%)")

    if outer_imb < OUTER_IMBALANCE_MIN:
        return (False, None, atm_c, atm_p, outer_c, outer_p,
                atm_imb, outer_imb,
                f"OUTER_IMB_LOW({outer_imb*100:.1f}%)")

    atm_dir   = "CALL" if atm_c   < atm_p   else "PUT"
    outer_dir = "CALL" if outer_c < outer_p else "PUT"

    if atm_dir != outer_dir:
        return (False, None, atm_c, atm_p, outer_c, outer_p,
                atm_imb, outer_imb,
                f"DIR_DISAGREE(ATM={atm_dir},OUT={outer_dir})")

    ratio = _atm_ratio(atm_c, atm_p)
    if ratio < MIN_ATM_RATIO:
        return (False, None, atm_c, atm_p, outer_c, outer_p,
                atm_imb, outer_imb,
                f"ATM_RATIO_LOW({ratio:.2f})")

    # outer/ATM noise filter (on absolute diffs)
    atm_diff   = abs(atm_c - atm_p)
    outer_diff = abs(outer_c - outer_p)
    outer_atm_r = outer_diff / atm_diff if atm_diff > 0 else 0
    if outer_atm_r > MAX_OUTER_ATM_RATIO:
        return (False, None, atm_c, atm_p, outer_c, outer_p,
                atm_imb, outer_imb,
                f"OUTER_ATM_RATIO_HIGH({outer_atm_r:.1f})")

    return (True, atm_dir, atm_c, atm_p, outer_c, outer_p,
            atm_imb, outer_imb, "OK")


